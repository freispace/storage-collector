{
  "productName": "freispace Storage Collector",
  "version": "0.1.0",
  "identifier": "com.freispace.storage-collector",
  "build": {
    "beforeDevCommand": "pnpm run dev:frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "Settings — freispace Storage Collector",
        "url": "settings.html",
        "width": 900,
        "height": 600,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "center": true
      },
      {
        "label": "logs",
        "title": "Logs — freispace Storage Collector",
        "url": "logs.html",
        "width": 900,
        "height": 500,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "linux": {
      "deb": {
        "depends": ["libayatana-appindicator3-1"]
      },
      "rpm": {
        "depends": ["libayatana-appindicator"]
      }
    },
    "copyright": "© Leonardo Re, freispace GmbH",
    "category": "Utility",
    "shortDescription": "Monitor folder sizes and submit to freispace",
    "longDescription": "A background tray application that monitors local folder sizes and submits storage statistics to the freispace API.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxRUQ0RThCQUU0OTg4NjgKUldSb2lFbXVpMDd0NGRqUGQ0VVpjSkVqNE1EVzBmeUx3Y3VaUkJRTDQzdHg1V2VTYXlnVGY0SHYK",
      "endpoints": [
        "https://github.com/freispace/storage-collector/releases/download/{{current_version}}/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
